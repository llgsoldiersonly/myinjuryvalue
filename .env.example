# --- SMS via textbee.dev (Android-gateway, no A2P 10DLC needed) ---
# https://textbee.dev/dashboard → API Keys + Devices
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=
# Set DISABLE_SMS=true to short-circuit all sendSms() calls (useful for staging
# or before textbee device pairing is complete). Calls + emails still work.
DISABLE_SMS=

# --- Resend ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="My Injury Value <noreply@myinjuryvalue.com>"

# --- Public/runtime ---
PUBLIC_BASE_URL=https://myinjuryvalue.com
CALLBACK_NUMBER=

# --- Dashboard auth (basic) ---
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me

# --- Intake email recipients (comma separated) ---
INTAKE_EMAIL_TO=
